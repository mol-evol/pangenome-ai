<header class="site-header">
  <div class="container header-inner">
    <a href="{{ "/" | relURL }}" class="site-brand" aria-label="Pangenome AI home">
      <svg class="brand-mark" width="32" height="32" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="1.5"/>
        <path d="M6 16 Q11 6, 16 16 T26 16" fill="none" stroke="currentColor" stroke-width="1.5"/>
        <path d="M6 16 Q11 26, 16 16 T26 16" fill="none" stroke="currentColor" stroke-width="1.5"/>
      </svg>
      <span class="brand-name">Pangenome <span class="brand-name-accent">AI</span></span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <button class="nav-toggle" aria-controls="primary-nav" aria-expanded="false">
        <span class="visually-hidden">Menu</span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
      <ul id="primary-nav" class="nav-list">
        {{ range .Site.Menus.main }}
          <li><a href="{{ .URL | relURL }}"{{ if $.IsMenuCurrent "main" . }} aria-current="page"{{ end }}>{{ .Name }}</a></li>
        {{ end }}
      </ul>
    </nav>
  </div>
</header>
<script>
  (function(){
    var btn = document.querySelector('.nav-toggle');
    var nav = document.getElementById('primary-nav');
    if(!btn || !nav) return;
    btn.addEventListener('click', function(){
      var open = nav.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  })();
</script>
